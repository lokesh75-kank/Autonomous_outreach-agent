# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Serper API (for Google Search)
SERPER_API_KEY=your-serper-api-key-here

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/outreach_db
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/outreach_db

# LinkedIn Configuration (session cookies - obtained after manual login)
LINKEDIN_SESSION_COOKIE=your-li_at-cookie-value
LINKEDIN_CSRF_TOKEN=your-csrf-token

# Rate Limiting (Safety)
MAX_CONNECTIONS_PER_DAY=20
MIN_DELAY_SECONDS=45
MAX_DELAY_SECONDS=120

# Optimal Outreach Windows (PST) - When Recruiters/HMs are most active
# Morning Rush: 8 AM - 10 AM (checking messages, reviewing applicants)
# Afternoon Boost: 2 PM - 4 PM (final check before end of day)
USE_OPTIMAL_WINDOWS=true
MORNING_WINDOW_START=8
MORNING_WINDOW_END=10
AFTERNOON_WINDOW_START=14
AFTERNOON_WINDOW_END=16

# Fallback working hours (used if USE_OPTIMAL_WINDOWS=false)
WORKING_HOURS_START=9
WORKING_HOURS_END=18

# Application Settings
DEBUG=false
LOG_LEVEL=INFO

# Dashboard
STREAMLIT_SERVER_PORT=8501

# API Server
API_HOST=0.0.0.0
API_PORT=8000
